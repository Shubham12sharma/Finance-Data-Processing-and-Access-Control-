{
  "info": {
    "name": "Finance Dashboard API",
    "description": "Comprehensive Postman collection for Finance Data Processing and Access Control Backend\n\nThis collection includes:\n- User Registration & Authentication (JWT)\n- Financial Records CRUD Operations\n- Advanced Filtering\n- Dashboard Analytics\n- Role-Based Access Control Examples\n\nBase URL: http://127.0.0.1:8000/api\n\nSetup Instructions:\n1. Import this collection into Postman\n2. Set the 'baseUrl' variable to your API base URL\n3. Set 'access_token' after login (automatically extracted)\n4. Test different roles by logging in with different users",
    "schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json",
    "_exporter_id": "1234567"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000/api",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "record_id",
      "value": "1",
      "type": "string"
    }
  ],
