      "name": "Authentication",
      "item": [
        {
          "name": "Register User - Viewer Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.test('User registered successfully', function() {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData.message).to.include('registered');",
                  "        pm.expect(jsonData.user.role).to.equal('viewer');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_viewer\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\",\n  \"password_confirm\": \"SecurePass123\",\n  \"role\": \"viewer\"\n}"
            },
            "url": {
