        {
          "name": "Login - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('access_token', jsonData.access);",
                  "    pm.environment.set('refresh_token', jsonData.refresh);",
                  "    ",
                  "    pm.test('Login successful and tokens received', function() {",
                  "        pm.expect(jsonData.access).to.exist;",
                  "        pm.expect(jsonData.refresh).to.exist;",
                  "    });",
                  "    ",
                  "    // Decode JWT to see payload",
                  "    console.log('Access Token set in environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"jane_analyst\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "login"
              ]
            },
            "description": "Login with username and password to get JWT tokens\n\n**Note:** Change username/password to match your test user\n\nResponse includes:\n- `access`: JWT token (valid for 60 minutes)\n- `refresh`: Refresh token (valid for 7 days)"
          },
          "response": []
        }
      ]
